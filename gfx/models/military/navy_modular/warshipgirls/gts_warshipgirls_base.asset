pdxmesh = {
	name = "gts_warshipgirls_base_mesh"
	file = "gts_warshipgirls_base.mesh"

	meshsettings = {
		name = "LOD_Group|LOD_0|flag_0"
		index = 0
		texture_diffuse = "flag_wrinkles_diffuse.dds"
		texture_normal = "flag_wrinkles_normal.dds"
		texture_specular = "flag_wrinkles_properties.dds"
		shader = "standard_flag_basic"
		shader_file = "gfx/FX/pdxmesh.shader"
		additional_shader_defines = { "COA_TEXTURE" }
	}

	meshsettings = {
		name = "LOD_Group|LOD_0|ship_base_0"
		index = 0
		texture_diffuse = "ship_gts_warshipgirls_base_diffuse.dds"
		texture_normal = "ship_gts_warshipgirls_base_normal.dds"
		texture_specular = "ship_gts_warshipgirls_base_properties.dds"
        texture = { file = "ship_gts_warshipgirls_base_colormask.dds" index = 6 }
        shader = "standard"
        additional_shader_defines = { "UNIT_COLOR" "EMISSIVE_NIGHT" }
        shader_file = "gfx/FX/pdxmesh.shader"
	}
	
	meshsettings = {
		name = "LOD_Group|LOD_0|ship_ropes_0"
		index = 0
		texture_diffuse = "generic_ship_alpha_diffuse.dds"
		texture_normal = "generic_ship_alpha_normal.dds"
		texture_specular = "generic_ship_alpha_properties.dds"
		shader = "standard_alpha_blend"
		additional_shader_defines = { "EMISSIVE_NIGHT" }
		shader_file = "gfx/FX/pdxmesh.shader"
	}
}

entity = {
	name = "gts_warshipgirls_base_entity"
	pdxmesh = "gts_warshipgirls_base_mesh"

	default_state = "idle"

	state = { name = "idle"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_idle" } }
	}

	state = { name = "move"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_moving" } }
		event = { time = 0 trigger_once = yes keep_sound = no sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_moving_start" } }
	}

	state = { name = "move_local"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_moving_local" } }
		event = { time = 0 trigger_once = yes keep_sound = no sound  = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_moving_start" } }
	}

	state = { name = "move_ship_viewer"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_moving_ship_viewer" } }
	}

	state = { name = "combat"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_combat" } }
	}

	state = { name = "destroyed"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/capital_ships/super_dreadnought/anm_ship_superdreadnought_destroyed" } }
	}
}

